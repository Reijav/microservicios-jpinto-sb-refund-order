                "api",
                "v1",
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parsear la respuesta JSON",
                  "let jsonData = pm.response.json();",
                  "",
                  "// Guardar el access token y refresh token en variables de entorno",
                  "pm.environment.set(\"accessToken\", jsonData.accessToken);",
                  "pm.environment.set(\"refreshToken\", jsonData.refreshToken);",
                  "",
                  "// (Opcional) guardar el tiempo de expiración si lo usas después",
                  "pm.environment.set(\"expiresIn\", jsonData.expiresIn);",
                  "",
                  "// Mostrar en consola para verificación",
                  "console.log(\"Access Token guardado:\", jsonData.accessToken);",
                  "console.log(\"Refresh Token guardado:\", jsonData.refreshToken);",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"supervisor\",\n    \"password\": \"supervisor123\"\n}"
            },
            "url": {
              "raw": "http://localhost:50300/api/v1/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "50300",
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parsear la respuesta JSON",
                  "let jsonData = pm.response.json();",
                  "",
                  "// Guardar el access token y refresh token en variables de entorno",
                  "pm.environment.set(\"accessToken\", jsonData.accessToken);",
                  "pm.environment.set(\"refreshToken\", jsonData.refreshToken);",
                  "",
                  "// (Opcional) guardar el tiempo de expiración si lo usas después",
                  "pm.environment.set(\"expiresIn\", jsonData.expiresIn);",
                  "",
                  "// Mostrar en consola para verificación",
                  "console.log(\"Access Token guardado:\", jsonData.accessToken);",
                  "console.log(\"Refresh Token guardado:\", jsonData.refreshToken);",
                  ""
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
