    {
      "name": "API AUTH",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"empleado3\",\n    \"password\": \"empleado123\",\n    \"roles\": [\"EMPLEADO\"]\n}"
            },
            "url": {
              "raw": "http://localhost:50300/api/v1/auth/register",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "50300",
